# Database Configuration Example
# Copy this file to tbqc_db.env and fill in your actual values
# DO NOT commit tbqc_db.env to git!
#
# ⚠️ SECURITY WARNING:
# - Never commit actual credentials to Git
# - Use environment variables in production (Railway, etc.)
# - Keep tbqc_db.env only on local machine

DB_HOST=your_database_host
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

# Application Passwords (for Members page actions: Add, Update, Delete, Backup)
# ⚠️ DO NOT commit actual passwords to Git! Chỉ lưu trong .env local
MEMBERS_PASSWORD=your_members_password_here
ADMIN_PASSWORD=your_admin_password_here
BACKUP_PASSWORD=your_backup_password_here

# Tài khoản cố định cổng Members (optional). Các mục cách nhau bằng dấu phẩy.
# Hỗ trợ 2 dạng giá trị (tự phát hiện):
#   - user1:plaintext_password         — tương thích ngược (KHÔNG khuyến nghị trên server)
#   - user2:$2b$12$<bcrypt_hash>...    — khuyến nghị; không lộ plaintext qua env/log/backup
# Tạo bcrypt hash: python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt(rounds=12)).decode())"
# Chỉ đặt trên Railway / env server — mật khẩu mạnh; đổi định kỳ nếu nghi lộ; không commit giá trị thật.
# MEMBERS_FIXED_ACCOUNTS=user1:pass1,user2:$2b$12$abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUV
# (Tùy chọn) Chỉ cho phép IP sau đăng nhập bằng tài khoản cố định (user DB không bị chặn). Để trống = không lọc IP.
# MEMBERS_GATE_IP_ALLOWLIST=203.0.113.1,198.51.100.2

# Mật khẩu album, xóa ảnh mộ (optional, fallback dùng MEMBERS_PASSWORD)
# ALBUM_PASSWORD=your_album_password
# GRAVE_IMAGE_DELETE_PASSWORD=your_grave_delete_password

# Passphrase mở trang Gia phả (phân cách bằng dấu phẩy, chỉ lưu local)
# GENEALOGY_PASSPHRASES=phrase1,phrase2,phrase3

# Flask session (bắt buộc cho production)
SECRET_KEY=your_secret_key_here

# Chỉ máy dev cục bộ: bật Werkzeug debugger + stack trace chi tiết (python start_server.py).
# Production / môi trường công khai: KHÔNG đặt hoặc để false — dùng Gunicorn (Procfile), không dùng start_server.
# FLASK_DEBUG=true

# Facebook API (optional)
FB_PAGE_ID=your_facebook_page_id
FB_ACCESS_TOKEN=your_facebook_access_token

# Genealogy sync TLS (optional).
# Mặc định: verify=True (verify chứng chỉ theo CA của hệ điều hành).
#   - GENEALOGY_SYNC_CA_BUNDLE=/path/to/ca.pem → dùng CA bundle tùy chỉnh (self-signed / CA nội bộ).
#   - GENEALOGY_SYNC_INSECURE_TLS=1           → TẮT verify (chỉ dev local). Tự động bị bỏ qua trên production.
# GENEALOGY_SYNC_CA_BUNDLE=
# GENEALOGY_SYNC_INSECURE_TLS=0

# Geoapify — GEOAPIFY_API_KEY chỉ dùng phía server (không trả qua /api/geoapify-key).
# Nếu cần key trên trình duyệt: tạo GEOAPIFY_BROWSER_KEY riêng và giới hạn HTTP Referrer trên dashboard Geoapify.
# Chỉ bật tạm nếu bắt buộc: GEOAPIFY_EXPOSE_SERVER_KEY_TO_BROWSER=1
# GEOAPIFY_BROWSER_KEY=
# GEOAPIFY_EXPOSE_SERVER_KEY_TO_BROWSER=0
GEOAPIFY_API_KEY=your_geoapify_api_key_here

# Session & Cookie (Production only - xử lý triệt để auto logout)
# Set COOKIE_DOMAIN để cookie dùng chung cho domain chính và www
# Ví dụ: .phongtuybienquancong.info (có dấu chấm đầu cho subdomain)
# Khi set → app dùng làm SESSION_COOKIE_DOMAIN và REMEMBER_COOKIE_DOMAIN
# Production cần HTTPS; SESSION_COOKIE_SECURE=True nên qua HTTP sẽ không gửi cookie
# COOKIE_DOMAIN=.phongtuybienquancong.info

# --- Tùy chọn bảo mật vận hành (Railway / production) ---
# Chi tiết đầy đủ /api/health (db host, user, port): đặt secret và gửi header X-Health-Detail-Key
# Không đặt → trên production response health chỉ còn server/database/stats (không lộ cấu hình DB).
# HEALTH_DETAIL_SECRET=

# Token cho POST /api/external-posts/clear-cache và GET|POST /api/external-posts/refresh (tránh spam).
# Không đặt → giữ hành vi cũ (không cần header). Đặt → bắt buộc X-External-Posts-Token hoặc X-Cache-Token (hoặc ?token= trên GET).
# EXTERNAL_POSTS_CACHE_SECRET=

# Rate limit thống nhất nhiều worker Gunicorn: thêm Redis trên Railway rồi đặt một trong hai biến
# REDIS_URL=redis://...
# RATELIMIT_STORAGE_URI=redis://...

# API nội bộ (fix dữ liệu gia phả / migration): bắt buộc trên production trừ khi đăng nhập admin.
# Gửi header: X-TBQC-Internal-Secret: <giá trị> — hoặc đăng nhập admin qua session.
# INTERNAL_API_SECRET=

# Chỉ môi trường dev/local: cho phép gọi /api/fix/... và /api/genealogy/update-info không cần auth (KHÔNG bật trên production).
# ALLOW_UNAUTHENTICATED_DATA_FIXES=0

